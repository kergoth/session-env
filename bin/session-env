#!/bin/sh
set -eu

# --- OS detection ---
detect_os() {
    case "$(uname -s)" in
        Darwin)  echo darwin ;;
        Linux)   echo linux ;;
        FreeBSD) echo freebsd ;;
        *)       echo unknown ;;
    esac
}

SESSION_ENV_OS="${SESSION_ENV_OS:-$(detect_os)}"
SESSION_ENV_FILE="${SESSION_ENV_FILE:-$HOME/.session-env}"

# --- Usage ---
usage() {
    cat <<'EOF'
usage: session-env <command> [args]

Commands:
    sync <launchctl|dbus>   Inject session vars into desktop environment
    get <name>              Resolve a credential from CLI tool or keychain
    set <name> [value]      Store a credential in the platform keychain
    delete <name>           Remove a credential from the platform keychain
    vars                    List discovered session variable names
    export                  Emit export statements for shell eval
    install                 Install desktop session auto-start
    uninstall               Remove desktop session auto-start
    help                    Show this help
EOF
}

# --- Discovery engine ---
# Source ~/.session-env in a clean env -i subprocess; diff to find exports.
# Passes through HOME and USER (needed by most session-env files).
# Outputs: VAR=value lines, one per discovered variable, sorted by name.
discover_vars() {
    [ -f "$SESSION_ENV_FILE" ] || return 0
    env -i HOME="$HOME" USER="${USER:-$(id -un)}" \
        sh -c '. "$1"; env' _ "$SESSION_ENV_FILE" 2>/dev/null |
    while IFS='=' read -r name rest; do
        case "$name" in
            HOME|USER|PWD|SHLVL|_) continue ;;
            ''|[!A-Za-z_]*) continue ;;
        esac
        printf '%s=%s\n' "$name" "$rest"
    done | sort
}

cmd_vars() {
    discover_vars | while IFS='=' read -r name _rest; do
        printf '%s\n' "$name"
    done
}

cmd_export() {
    discover_vars | while IFS='=' read -r name rest; do
        printf 'export %s="%s"\n' "$name" "$rest"
    done
}

# --- Stubs (replaced in subsequent tasks) ---
cmd_sync()      { echo "not implemented" >&2; exit 1; }
cmd_get()       { echo "not implemented" >&2; exit 1; }
cmd_set()       { echo "not implemented" >&2; exit 1; }
cmd_delete()    { echo "not implemented" >&2; exit 1; }
cmd_install()   { echo "not implemented" >&2; exit 1; }
cmd_uninstall() { echo "not implemented" >&2; exit 1; }

# --- Dispatch ---
cmd="${1:-}"
[ -n "$cmd" ] || { usage >&2; exit 2; }
shift

case "$cmd" in
    sync)      cmd_sync "$@" ;;
    get)       cmd_get "$@" ;;
    set)       cmd_set "$@" ;;
    delete)    cmd_delete "$@" ;;
    vars)      cmd_vars "$@" ;;
    export)    cmd_export "$@" ;;
    install)   cmd_install "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help)      usage; exit 0 ;;
    *)         usage >&2; exit 2 ;;
esac
