#!/bin/sh
set -eu

# --- OS detection ---
detect_os() {
    case "$(uname -s)" in
        Darwin)  echo darwin ;;
        Linux)   echo linux ;;
        FreeBSD) echo freebsd ;;
        *)       echo unknown ;;
    esac
}

SESSION_ENV_OS="${SESSION_ENV_OS:-$(detect_os)}"
SESSION_ENV_FILE="${SESSION_ENV_FILE:-$HOME/.session-env}"
SESSION_ENV_SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
SESSION_ENV_LAUNCHAGENT_DIR="${SESSION_ENV_LAUNCHAGENT_DIR:-$HOME/Library/LaunchAgents}"
SESSION_ENV_AUTOSTART_DIR="${SESSION_ENV_AUTOSTART_DIR:-$HOME/.config/autostart}"

LAUNCHAGENT_LABEL="com.session-env"
LAUNCHAGENT_FILE="$SESSION_ENV_LAUNCHAGENT_DIR/$LAUNCHAGENT_LABEL.plist"
AUTOSTART_FILE="$SESSION_ENV_AUTOSTART_DIR/session-env.desktop"

# --- Usage ---
usage() {
    cat <<'EOF'
usage: session-env <command> [args]

Commands:
    sync <launchctl|dbus>   Inject session vars into desktop environment
    get <name>              Resolve a credential from CLI tool or keychain
    set <name> [value]      Store a credential in the platform keychain
    delete <name>           Remove a credential from the platform keychain
    vars                    List discovered session variable names
    export                  Emit export statements for shell eval
    install                 Install desktop session auto-start
    uninstall               Remove desktop session auto-start
    help                    Show this help
EOF
}

# --- Discovery engine ---
# Source ~/.session-env in a clean env -i subprocess; diff to find exports.
# Passes through HOME and USER (needed by most session-env files).
# Outputs: VAR=value lines, one per discovered variable, sorted by name.
discover_vars() {
    [ -f "$SESSION_ENV_FILE" ] || return 0
    env -i HOME="$HOME" USER="${USER:-$(id -un)}" \
        sh -c '. "$1"; env' _ "$SESSION_ENV_FILE" 2>/dev/null |
    while IFS='=' read -r name rest; do
        case "$name" in
            HOME|USER|PWD|SHLVL|_) continue ;;
            ''|[!A-Za-z_]*) continue ;;
        esac
        printf '%s=%s\n' "$name" "$rest"
    done | sort
}

cmd_vars() {
    discover_vars | while IFS='=' read -r name _rest; do
        printf '%s\n' "$name"
    done
}

cmd_export() {
    discover_vars | while IFS='=' read -r name rest; do
        printf 'export %s="%s"\n' "$name" "$rest"
    done
}

# --- CLI credential sources ---
# Returns the value from a tool's own auth, if available.
# Add new CLI-sourced credentials here.
lookup_cli() {
    case "$1" in
        GITHUB_TOKEN)
            command -v gh >/dev/null 2>&1 || return 1
            env GITHUB_TOKEN= gh auth token 2>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}

# --- Platform keychain ---
keychain_get() {
    case "$SESSION_ENV_OS" in
        darwin)
            command -v security >/dev/null 2>&1 || return 1
            security find-generic-password -s "$1" -a "${USER:-$(id -un)}" -w 2>/dev/null
            ;;
        linux|freebsd)
            command -v secret-tool >/dev/null 2>&1 || return 1
            secret-tool lookup service session-env key "$1" 2>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}

keychain_set() {
    case "$SESSION_ENV_OS" in
        darwin)
            command -v security >/dev/null 2>&1 || { echo "security command not found" >&2; exit 1; }
            security add-generic-password -U -s "$1" -a "${USER:-$(id -un)}" -w "$2" >/dev/null
            ;;
        linux|freebsd)
            command -v secret-tool >/dev/null 2>&1 || { echo "secret-tool not found" >&2; exit 1; }
            printf '%s' "$2" |
                secret-tool store --label="$1" service session-env key "$1" >/dev/null
            ;;
        *)
            printf 'unsupported OS for keychain: %s\n' "$SESSION_ENV_OS" >&2
            exit 1
            ;;
    esac
}

keychain_delete() {
    case "$SESSION_ENV_OS" in
        darwin)
            command -v security >/dev/null 2>&1 || { echo "security command not found" >&2; exit 1; }
            security delete-generic-password -s "$1" -a "${USER:-$(id -un)}" >/dev/null
            ;;
        linux|freebsd)
            command -v secret-tool >/dev/null 2>&1 || { echo "secret-tool not found" >&2; exit 1; }
            secret-tool clear service session-env key "$1" >/dev/null
            ;;
        *)
            printf 'unsupported OS for keychain: %s\n' "$SESSION_ENV_OS" >&2
            exit 1
            ;;
    esac
}

cmd_get() {
    name="${1:-}"
    [ -n "$name" ] || { printf 'usage: session-env get <name>\n' >&2; exit 2; }

    # Prefer CLI source
    if value=$(lookup_cli "$name" 2>/dev/null) && [ -n "$value" ]; then
        printf '%s' "$value"
        return 0
    fi

    # Fall back to keychain
    if value=$(keychain_get "$name") && [ -n "$value" ]; then
        printf '%s' "$value"
        return 0
    fi

    # Not found — exit 0 with no output
    return 0
}

cmd_set() {
    name="${1:-}"
    [ -n "$name" ] || { printf 'usage: session-env set <name> [value]\n' >&2; exit 2; }

    if [ $# -gt 1 ]; then
        value="$2"
    else
        if [ -t 0 ]; then
            printf 'missing value; pass as argument or pipe on stdin\n' >&2
            exit 2
        fi
        IFS= read -r value || value=
    fi

    keychain_set "$name" "$value"
}

cmd_delete() {
    name="${1:-}"
    [ -n "$name" ] || { printf 'usage: session-env delete <name>\n' >&2; exit 2; }
    keychain_delete "$name"
}

cmd_sync() {
    backend="${1:-}"
    case "$backend" in
        launchctl|dbus) ;;
        '') printf 'usage: session-env sync <launchctl|dbus>\n' >&2; exit 2 ;;
        *)  printf 'unknown backend: %s\n' "$backend" >&2; exit 2 ;;
    esac

    discover_vars | while IFS='=' read -r name val; do
        case "$backend" in
            launchctl)
                target_uid=$(launchctl manageruid 2>/dev/null || id -u)
                launchctl asuser "$target_uid" launchctl setenv "$name" "$val"
                ;;
            dbus)
                dbus-update-activation-environment "$name=$val"
                ;;
        esac
    done
}

cmd_install() {
    case "$SESSION_ENV_OS" in
        darwin)
            mkdir -p "$SESSION_ENV_LAUNCHAGENT_DIR"
            cat > "$LAUNCHAGENT_FILE" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>$LAUNCHAGENT_LABEL</string>

	<key>ProgramArguments</key>
	<array>
		<string>$SESSION_ENV_SELF</string>
		<string>sync</string>
		<string>launchctl</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>StandardOutPath</key>
	<string>$HOME/Library/Logs/session-env.log</string>
	<key>StandardErrorPath</key>
	<string>$HOME/Library/Logs/session-env.log</string>
</dict>
</plist>
EOF
            printf 'Installed %s\n' "$LAUNCHAGENT_FILE" >&2
            printf 'Run "launchctl load %s" to activate now, or it will start at next login.\n' "$LAUNCHAGENT_FILE" >&2
            ;;
        linux|freebsd)
            mkdir -p "$SESSION_ENV_AUTOSTART_DIR"
            cat > "$AUTOSTART_FILE" << EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=Session Environment
Comment=Inject session vars into the desktop activation environment
Exec=$SESSION_ENV_SELF sync dbus
X-KDE-autostart-after=panel
X-KDE-StartupNotify=false
EOF
            printf 'Installed %s\n' "$AUTOSTART_FILE" >&2
            printf 'Will activate at next login.\n' >&2
            ;;
        *)
            printf 'unsupported OS: %s\n' "$SESSION_ENV_OS" >&2
            exit 1
            ;;
    esac
}

cmd_uninstall() {
    case "$SESSION_ENV_OS" in
        darwin)
            if [ -f "$LAUNCHAGENT_FILE" ]; then
                launchctl unload "$LAUNCHAGENT_FILE" 2>/dev/null || true
                rm -f "$LAUNCHAGENT_FILE"
                printf 'Removed %s\n' "$LAUNCHAGENT_FILE" >&2
            else
                printf 'No LaunchAgent installed.\n' >&2
            fi
            ;;
        linux|freebsd)
            if [ -f "$AUTOSTART_FILE" ]; then
                rm -f "$AUTOSTART_FILE"
                printf 'Removed %s\n' "$AUTOSTART_FILE" >&2
            else
                printf 'No autostart entry installed.\n' >&2
            fi
            ;;
        *)
            printf 'unsupported OS: %s\n' "$SESSION_ENV_OS" >&2
            exit 1
            ;;
    esac
}

# --- Dispatch ---
cmd="${1:-}"
[ -n "$cmd" ] || { usage >&2; exit 2; }
shift

case "$cmd" in
    sync)      cmd_sync "$@" ;;
    get)       cmd_get "$@" ;;
    set)       cmd_set "$@" ;;
    delete)    cmd_delete "$@" ;;
    vars)      cmd_vars "$@" ;;
    export)    cmd_export "$@" ;;
    install)   cmd_install "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help)      usage; exit 0 ;;
    *)         usage >&2; exit 2 ;;
esac
